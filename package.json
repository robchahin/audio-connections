{
  "name": "audio-connections",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "VITE_HTTPS=1 vite --host",
    "build": "tsc --noEmit && vite build",
    "wasm:build": "bash wasm/build.sh",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:itunes": "vitest run --config vitest.itunes.config.ts",
    "test:watch": "vitest",
    "test:past-days": "node scripts/check-past-days.ts",
    "schedule:preview": "node scripts/schedule-preview.ts",
    "validate": "npm run typecheck && npm run test:unit && npm run test:itunes && npm run test:past-days",
    "setup": "npm ci && npx playwright install && git config core.hooksPath .githooks"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
